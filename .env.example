# ============================================
# Decorador.net — Environment Variables
# ============================================

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database (Prisma → Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres

# App
PORT=3000
NODE_ENV=development

# Escrow / Payments
ESCROW_COMMISSION_RATE=0.15

# Storage (Supabase)
# Bucket público = decorador-files (fotos, portfolio, etc.)
# Bucket privado do chat (anexos) — criar no Supabase como private
STORAGE_CHAT_BUCKET=decorador-chat

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
